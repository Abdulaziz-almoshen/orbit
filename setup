#!/usr/bin/env bash
#
# setup — finish an Orbit install after cloning into ~/.claude/skills/orbit (the gstack way).
#
#   git clone --single-branch --depth 1 https://github.com/Abdulaziz-almoshen/orbit.git \
#       ~/.claude/skills/orbit && cd ~/.claude/skills/orbit && ./setup
#
# The clone IS the skill dir, so there's nothing to copy — setup just makes the helpers
# executable, exposes the orbit-upgrade sub-skill at the top level so /orbit-upgrade resolves,
# and prints what landed (incl. the resolved commit, so you have a checkable record of exactly
# what's installed). No restart: Claude Code discovers skills live. Updates are a fetch + reset
# to the latest commit on the tracked branch (via /orbit-upgrade), not a merge — local edits to
# the installed copy are stashed first, never silently discarded. Idempotent and safe to re-run.
#
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd -P)"
SKILLS_DIR="$(dirname "$HERE")"          # parent of the orbit dir = ~/.claude/skills

# 1. make the helpers executable (clone doesn't always preserve the +x bit)
chmod +x "$HERE"/bin/* 2>/dev/null || true
chmod +x "$HERE"/scripts/*.py 2>/dev/null || true
chmod +x "$HERE"/assets/checks/*.py 2>/dev/null || true

VER="$(tr -d '[:space:]' < "$HERE/VERSION" 2>/dev/null || echo '?')"
SHA="$(git -C "$HERE" rev-parse --short HEAD 2>/dev/null || echo 'not a git checkout')"

# Record verifiable-install metadata in ORBIT_HOME (version/commit/tag/manifest-checksum/channel/time),
# so `orbit-verify` and `/orbit-upgrade` can state exactly what's installed. A checksums.txt.asc (signed
# in CI) would make `channel` "release"; without it we honestly record "dev" (unsigned mutable branch).
_TAG="$(git -C "$HERE" describe --tags --exact-match 2>/dev/null || echo '')"
_CKSUM="$(shasum -a 256 "$HERE/checksums.txt" 2>/dev/null | cut -d' ' -f1 || echo '')"
_CHANNEL="dev"; [ -f "$HERE/checksums.txt.asc" ] && _CHANNEL="release"
_OH="${ORBIT_HOME:-$HOME/.orbit}"; mkdir -p "$_OH" 2>/dev/null || true
_INSTALLED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo '')"
printf '{\n  "version": "%s",\n  "commit": "%s",\n  "tag": "%s",\n  "manifest_sha256": "%s",\n  "channel": "%s",\n  "path": "%s",\n  "installed_at": "%s"\n}\n' \
  "$VER" "$SHA" "$_TAG" "$_CKSUM" "$_CHANNEL" "$HERE" "$_INSTALLED_AT" > "$_OH/install.json" 2>/dev/null || true

# 2. is this a valid install location? (~/.claude/skills/orbit) — decide BEFORE touching anything
#    outside $HERE, so a mis-placed clone leaves no stray symlinks in the parent dir.
_expect="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills"
_expect="$(cd "$_expect" 2>/dev/null && pwd -P || echo "$_expect")"   # resolve symlinks (e.g. /tmp→/private/tmp)
UNINSTALL="$HERE/bin/orbit-uninstall"

printf '\n'
if [ "$SKILLS_DIR" = "$_expect" ] && [ "$(basename "$HERE")" = "orbit" ]; then
  # 2a. expose sub-skills at the top level so they're invocable as /orbit-upgrade
  if [ -d "$HERE/orbit-upgrade" ]; then
    ln -sfn "$HERE/orbit-upgrade" "$SKILLS_DIR/orbit-upgrade" 2>/dev/null \
      || cp -R "$HERE/orbit-upgrade" "$SKILLS_DIR/orbit-upgrade" 2>/dev/null || true
  fi
  # 2b. make orbit-uninstall resolvable by name if ~/.local/bin is on PATH; else use the full path
  if printf '%s' ":$PATH:" | grep -q ":$HOME/.local/bin:" 2>/dev/null; then
    mkdir -p "$HOME/.local/bin" 2>/dev/null || true
    if ln -sfn "$UNINSTALL" "$HOME/.local/bin/orbit-uninstall" 2>/dev/null; then
      UNINSTALL="orbit-uninstall"
    fi
  fi
  printf '✅ Orbit v%s installed → %s\n' "$VER" "$HERE"
  printf '   Run /orbit in any repo. No restart — Claude Code discovers skills live.\n'
else
  printf '⚠️  Orbit v%s is at %s\n' "$VER" "$HERE"
  printf '   For /orbit to load, this must be at %s/skills/orbit. Re-clone there.\n' "${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
  printf '   (Skipped the /orbit-upgrade symlink — not installing into a non-skills dir.)\n'
fi
printf '   Commit: %s\n' "$SHA"
printf '   Update: /orbit-upgrade (fetch + reset to latest).  Uninstall: %s\n' "$UNINSTALL"
