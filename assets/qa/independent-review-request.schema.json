{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orbit Independent Review Request",
  "type": "object",
  "required": ["schema_version", "id", "goal", "baseline_commit", "acceptance_criteria", "armed"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$" },
    "goal": { "type": "string", "minLength": 1 },
    "baseline_commit": { "type": "string", "minLength": 7 },
    "scope": { "type": "object" },
    "rubric_files": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean", "default": true },
          "evidence": { "type": "string" }
        }
      }
    },
    "armed": {
      "type": "object", "required": ["approved", "approved_by", "approved_at"],
      "properties": {
        "approved": { "const": true },
        "approved_by": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "minLength": 1 }
      }
    }
  }
}
