#!/usr/bin/env python3
"""
orbit-status — live run dashboard for an Orbit run (the headless equivalent of the pinned
Claude Code checklist). Reads the telemetry activity.py writes:

    .orbit/run.json         the compact snapshot (phase, active role, progress, budget, confidence)
    .orbit/tasks.json       the checklist
    .orbit/activity.jsonl   the who-said-what thread

Modes:
    scripts/orbit-status              one-shot snapshot
    scripts/orbit-status --follow     redraw ~1/s, like a pinned dashboard
    scripts/orbit-status --compact    a 3-line summary (for a narrow pane)
    scripts/orbit-status --json       machine-readable snapshot (run + tasks + confidence)
    scripts/orbit-status --no-ansi    plain text (also honors NO_COLOR=1)
    scripts/orbit-status --tail 40    show the last N thread lines

Stdlib only. FULLY DEFENSIVE — a missing/garbage run.json or one bad event line never crashes it.
Set ORBIT_DIR to point at a different state dir.
"""
import json
import os
import re
import sys
import time
from pathlib import Path

# Defense-in-depth: strip any ANSI/terminal escapes + control chars AND scrub anything that looks
# like a secret before it reaches the terminal — the writers redact, but a legacy or hand-edited
# activity.jsonl line must never inject codes or display a leaked key.
_STRIP = re.compile(
    r"\x1b\][^\x07\x1b]*(?:\x07|\x1b\\)?"
    r"|\x1b[\^_P][^\x1b]*(?:\x1b\\)?"
    r"|\x1b\[[0-9;?]*[ -/]*[@-~]"
    r"|[\x00-\x1f\x7f\x9b]"
)
_SECRET = re.compile(
    r"\bsk-(?:proj|ant|live|test)-[A-Za-z0-9_\-]{6,}"
    r"|\b(?:sk|pk|rk)-[A-Za-z0-9]{16,}"
    r"|\b(?:ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{16,}|\bgithub_pat_[A-Za-z0-9_]{20,}"
    r"|\bAKIA[0-9A-Z]{16}\b|\bASIA[0-9A-Z]{16}\b|\bxox[baprs]-[A-Za-z0-9\-]{10,}"
    r"|\bAIza[0-9A-Za-z_\-]{20,}"
    r"|\beyJ[A-Za-z0-9_\-]{8,}\.[A-Za-z0-9_\-]{8,}\.[A-Za-z0-9_\-]{4,}",
    re.IGNORECASE,
)


def safe(text):
    return _SECRET.sub("[redacted]", _STRIP.sub(" ", str(text if text is not None else ""))).strip()

ORBIT_DIR = Path(os.environ.get("ORBIT_DIR", ".orbit"))
TASKS = ORBIT_DIR / "tasks.json"
ACTIVITY = ORBIT_DIR / "activity.jsonl"
RUN = ORBIT_DIR / "run.json"
PENDING = ORBIT_DIR / "pending-question.json"
AGENTS = ORBIT_DIR / "agents.json"

_NO_COLOR = bool(os.environ.get("NO_COLOR")) or "--no-ansi" in sys.argv
DIM = "" if _NO_COLOR else "\033[2m"
B = "" if _NO_COLOR else "\033[1m"
RST = "" if _NO_COLOR else "\033[0m"
_C = {"red": "\033[31m", "grn": "\033[32m", "ylw": "\033[33m", "cyn": "\033[36m", "mag": "\033[35m"}


def c(name):
    return "" if _NO_COLOR else _C.get(name, "")


ROLE_COLORS = {
    "dispatcher": "\033[96m", "router": "\033[96m",
    "orchestrator": "\033[35m", "pm": "\033[35m", "planner": "\033[35m",
    "product-discovery": "\033[94m", "market-researcher": "\033[36m",
    "data": "\033[36m", "input": "\033[36m",
    "builder": "\033[32m", "executor": "\033[32m", "engineer": "\033[32m", "frontend-engineer": "\033[32m",
    "designer": "\033[95m", "analyst": "\033[34m",
    "safety": "\033[31m", "reviewer": "\033[33m", "qa-engineer": "\033[93m", "qa": "\033[93m",
    "reporter": "\033[37m", "human": "\033[1;33m", "subagent": "\033[36m",
}
TASK_MARK = {"done": "✓", "in_progress": "▸", "pending": "○", "skipped": "⊘"}
EVENT_BADGE = {"done": "✓", "start": "▸", "blocked": "✗", "failed": "✗", "info": "·"}


def role_color(role):
    if _NO_COLOR:
        return ""
    key = (role or "").lower().replace("/", " ").split()[0] if role else ""
    return ROLE_COLORS.get(key, "\033[37m")


def _load(path, default):
    try:
        return json.loads(path.read_text())
    except Exception:
        return default


def load_events(n):
    try:
        lines = [l for l in ACTIVITY.read_text().splitlines() if l.strip()]
    except Exception:
        return []
    out = []
    for l in lines[-n:]:
        try:
            ev = json.loads(l)
            if isinstance(ev, dict):
                out.append(ev)
        except Exception:
            continue
    return out


def actor(e):
    return e.get("role") or e.get("who") or "?"


def fmt_ts(e):
    ts = str(e.get("ts", ""))
    return ts[11:19] if len(ts) >= 19 and "T" in ts else ts[:8]


def _age(iso_ts):
    try:
        t = time.strptime(str(iso_ts), "%Y-%m-%dT%H:%M:%SZ")
        return max(0, int(time.time() - time.mktime(t) + time.timezone))
    except Exception:
        return None


def _fmt_dur(secs, fine=False):
    if secs is None:
        return "?"
    if secs < 60:
        return f"{secs}s"
    if secs < 3600:
        return f"{secs // 60}m {secs % 60}s" if fine else f"{secs // 60}m"
    return f"{secs // 3600}h{(secs % 3600) // 60}m"


def _bar(done, total, width=10):
    if not total:
        return "[" + "-" * width + "]"
    fill = int(round(width * done / total))
    return "[" + "#" * fill + "-" * (width - fill) + "]"


def _confidence(run, events):
    """(score, reason) — computed from proof events via the confidence module if provisioned,
    else the running value on run.json."""
    proofs = [e.get("proof") for e in events if isinstance(e.get("proof"), dict)]
    blockers = 1 if run.get("blocked_question") else 0
    try:
        sys.path.insert(0, str(ORBIT_DIR))
        import confidence  # noqa: E402
        r = confidence.evaluate(proofs, blockers=blockers)
        return r["score"], r["reason"]
    except Exception:
        s = run.get("confidence")
        return (s, f"{s}%") if isinstance(s, (int, float)) else (None, "")


def _lifecycle_strip(run):
    mode = run.get("mode") or "feature"
    phase = run.get("phase") or ""
    try:
        sys.path.insert(0, str(ORBIT_DIR))
        import lifecycle  # noqa: E402
        return lifecycle.strip(mode, phase)
    except Exception:
        return mode


def _active_roles(events):
    """Roles whose latest event is start/info (working) — 'done'/'failed' clears them."""
    last = {}
    for e in events:
        r = actor(e)
        if r and r != "?":
            last[r] = (e.get("status", ""), e.get("msg", ""), e.get("ts", ""))
    return [(r, msg, ts) for r, (st, msg, ts) in last.items() if st in ("start", "info")]


def load_agents():
    a = _load(AGENTS, {})
    return a if isinstance(a, dict) else {}


def _quiet_note(secs):
    """The escalating 'is anything happening?' label (60 / 180 / 300s), or '' when fresh."""
    if secs is None or secs < 60:
        return ""
    if secs < 180:
        return f"quiet {_fmt_dur(secs)}"
    if secs < 300:
        return f"long step — {_fmt_dur(secs)} quiet"
    return f"possibly stuck — {_fmt_dur(secs)} quiet"


def _team(agents):
    """(active[], queued[]) sorted by declared seq, each an agent dict + its role key."""
    items = [dict(v, role=k) for k, v in agents.items() if isinstance(v, dict)]
    items.sort(key=lambda x: (x.get("seq", 99), x.get("role", "")))
    active = [x for x in items if x.get("status") in ("active", "blocked")]
    queued = [x for x in items if x.get("status") == "queued"]
    return active, queued


def render_team(run, agents, events):
    """The manager-visible standup board: who's working now (+ what/last signal/next) and who's
    queued. This is the thing the checklist alone can't give — a team, not a to-do list."""
    out = []
    active, queued = _team(agents)
    out.append(f"{B}Working now{RST}")
    if not active:
        out.append(f"  {DIM}(no agent active — orchestrator between steps){RST}")
    for a in active:
        el = _fmt_dur(_age(a.get("started_at")), fine=True) if a.get("started_at") else "?"
        quiet = _quiet_note(_age(a.get("last_event_at")))
        col = role_color(a.get("role", ""))
        head = f"  ▸ {col}{B}{safe(a.get('display', a.get('role', '')))}{RST}  {DIM}active {el}{RST}"
        if a.get("task"):
            head += f"  {DIM}· {safe(a['task'])}{RST}"
        if quiet:
            head += f"  {c('ylw') if ('stuck' in quiet or 'long' in quiet) else DIM}({quiet}){RST}"
        out.append(head)
        # description = the mission (what this stint is about); fall back to the role's responsibility
        desc = safe(a.get("mission")) or safe(a.get("responsibility"))
        if desc:
            out.append(f"    {desc}")
        last = safe(a.get("last_message"))
        if last and last != safe(a.get("mission")):
            out.append(f"    {DIM}Last signal: {last}{RST}")
        nxt = queued[0] if queued else None
        if nxt:
            out.append(f"    {DIM}Next: {safe(nxt.get('display', nxt.get('role','')))} "
                       f"— {safe(nxt.get('responsibility',''))}{RST}")
    if queued:
        out.append("")
        out.append(f"{B}Queued{RST}")
        for a in queued:
            col = role_color(a.get("role", ""))
            out.append(f"  ○ {col}{safe(a.get('display', a.get('role','')))}{RST}  "
                       f"{DIM}{safe(a.get('responsibility',''))}{RST}")
    return out


def _progress_line(run, agents, events):
    done, total = run.get("tasks_done", 0), run.get("tasks_total", 0)
    active, _ = _team(agents)
    score, _ = _confidence(run, events)
    bits = [f"{done}/{total} done"] if total else []
    bits.append(f"{len(active)} active")
    if score is not None:
        bits.append(f"confidence {int(score)}%")
    bits.append("blocked: " + run["blocked_question"][:40] if run.get("blocked_question") else "no blocker")
    q = _quiet_note(_age(run.get("last_ts")))
    if q:
        bits.append(q)
    return " · ".join(bits)


def _snapshot(run, events):
    """The machine-readable summary for --json."""
    score, reason = _confidence(run, events)
    return {
        "run_id": run.get("run_id"), "mode": run.get("mode"), "phase": run.get("phase"),
        "active_role": run.get("active_role"), "cycle": run.get("cycle"),
        "tasks_done": run.get("tasks_done", 0), "tasks_total": run.get("tasks_total", 0),
        "tokens": run.get("tokens", 0), "cost_usd": run.get("cost_usd", 0.0),
        "confidence": score, "confidence_reason": reason,
        "blocked_question": run.get("blocked_question"),
        "pending_question": _load(PENDING, None),
        "elapsed_s": _age(run.get("started_ts")), "last_event_age_s": _age(run.get("last_ts")),
    }


def render_compact(run, tasks, events):
    done, total = run.get("tasks_done", 0), run.get("tasks_total", 0)
    score, _ = _confidence(run, events)
    seg = [f"{B}🛰 {run.get('phase') or run.get('mode') or 'orbit'}{RST}"]
    if run.get("blocked_question"):
        seg.append(f"{c('ylw')}⚠ needs input{RST}")
    if total:
        seg.append(f"{_bar(done, total)} {done}/{total}")
    if isinstance(run.get("cost_usd"), (int, float)):
        seg.append(f"${run['cost_usd']:.2f}")
    if score is not None:
        seg.append(f"conf {int(score)}%")
    line = "  ".join(seg)
    ev = events[-1] if events else None
    tail = f"\n{DIM}last: {fmt_ts(ev)} [{actor(ev)}] {safe(ev.get('msg',''))}{RST}" if ev else ""
    return line + tail


def render_full(run, tasks, events, tail, agents=None):
    agents = agents if agents is not None else load_agents()
    out = []
    goal = safe(run.get("goal") or "")
    active_now, _ = _team(agents)
    slice_ = safe((active_now[0].get("task") if active_now else "") or run.get("active_task") or "")
    header = f"{B}🛰  Orbit{RST}"
    if slice_:
        header += f"  {DIM}· {slice_}{RST}"
    if goal:
        header += f"  {DIM}{goal}{RST}"
    out.append(header)
    if run:
        out.append(f"{B}Lifecycle{RST}  {_lifecycle_strip(run)}")
        out.append("")

    card = _load(PENDING, None)
    if isinstance(card, dict) and card.get("title"):
        out.append(f"{c('ylw')}{B}❓ Decision needed{RST}  {safe(card['title'])}")
        if card.get("why"):
            out.append(f"  {DIM}{safe(card['why'])}{RST}")
        for o in card.get("options", []):
            if not isinstance(o, dict):
                continue
            oid = safe(o.get("id", ""))
            rec = f" {c('grn')}(recommended){RST}" if oid and oid == safe(card.get("recommended")) else ""
            out.append(f"    {B}{oid}{RST} {safe(o.get('label', ''))}{rec}  {DIM}{safe(o.get('tradeoff', ''))}{RST}")
        out.append("")
    elif run.get("blocked_question"):
        out.append(f"{c('ylw')}{B}⚠ Needs input{RST}  {safe(run['blocked_question'])}")
        out.append("")

    # The team board — who's working now + who's queued. Above the checklist, by design.
    out.extend(render_team(run, agents, events))
    out.append("")
    out.append(f"{B}Progress{RST}    {_progress_line(run, agents, events)}")
    if run:
        el = _fmt_dur(_age(run.get("started_ts")))
        out.append(f"            {DIM}{_bar(run.get('tasks_done', 0), run.get('tasks_total', 0))} "
                   f"cycle {run.get('cycle', 0)} · {el} elapsed{RST}")
    out.append("")

    out.append(f"{B}Checklist{RST}")
    if not tasks:
        out.append(f"  {DIM}(no tasks yet){RST}")
    for t in (tasks or []):
        if not isinstance(t, dict):
            continue
        mark = TASK_MARK.get(t.get("status", "pending"), "○")
        owner = t.get("owner", "")
        own = f"{role_color(owner)}[{owner}]{RST} " if owner else ""
        line = f"  {mark} {own}{safe(t.get('title', ''))}"
        out.append(f"{DIM}{line}{RST}" if t.get("status") == "done" else line)
    out.append("")

    if run:
        cost = run.get("cost_usd", 0.0)
        toks = run.get("tokens", 0)
        out.append(f"{B}Budget{RST}     cost ${cost:.2f}   {toks} tokens")
        score, reason = _confidence(run, events)
        if score is not None:
            col = c("grn") if score >= 75 else c("ylw") if score >= 50 else c("red")
            out.append(f"{B}Confidence{RST} {col}{reason}{RST}")
        out.append("")

    # last event + stall detection
    ev = events[-1] if events else None
    if ev:
        age = _age(ev.get("ts")) or 0
        note = ""
        if age >= 90:
            note = f"  {c('red')}(possibly stalled — last event {_fmt_dur(age)} ago){RST}"
        elif age >= 30:
            note = f"  {c('ylw')}(still waiting on the active agent){RST}"
        out.append(f"{B}Last event{RST}  {DIM}{_fmt_dur(age)} ago{RST} "
                   f"{role_color(actor(ev))}[{actor(ev)}]{RST} {safe(ev.get('msg',''))}{note}")

    out.append("")
    out.append(f"{B}Thread{RST} {DIM}(who said what){RST}")
    if not events:
        out.append(f"  {DIM}(waiting for activity…){RST}")
    for e in events[-tail:]:
        try:
            who = actor(e)
            badge = EVENT_BADGE.get(e.get("status", "info"), "·")
            ph = e.get("phase", "")
            out.append(f"  {DIM}{fmt_ts(e)}{RST} {role_color(who)}{badge} [{who}]{RST} "
                       f"{safe(ph) + ': ' if ph else ''}{safe(e.get('msg', ''))}")
        except Exception:
            continue
    return "\n".join(out)


def render_team_board(run, agents, events):
    """The standalone team board (--team): the manager view + progress, nothing else. Meant to be
    printed inline before a long wait so the user never stares at only 'waiting for background agent'."""
    out = [f"{B}🛰  Orbit — team{RST}"]
    out.extend(render_team(run, agents, events))
    out.append(f"{DIM}{_progress_line(run, agents, events)}{RST}")
    return "\n".join(out)


def render(mode, tail):
    run = _load(RUN, {})
    if not isinstance(run, dict):
        run = {}
    tasks = _load(TASKS, [])
    # RUN ISOLATION: scope events to the CURRENT run_id so an old run's proof/thread can't leak
    # into this run's confidence or dashboard. An event with no run_id (legacy schema-1) is kept.
    rid = run.get("run_id")
    events_all = load_events(max(tail, 400))
    events = [e for e in events_all if e.get("run_id", rid) == rid] if rid else events_all
    agents = load_agents()
    if mode == "json":
        return json.dumps({"run": _snapshot(run, events), "agents": agents,
                           "tasks": tasks if isinstance(tasks, list) else []}, indent=2)
    if mode == "team":
        return render_team_board(run, agents, events)
    if mode == "compact":
        return render_compact(run, tasks, events)
    return render_full(run, tasks, events, tail, agents)


def main():
    argv = sys.argv[1:]
    follow = "--follow" in argv or "-f" in argv
    mode = ("json" if "--json" in argv else "team" if "--team" in argv
            else "compact" if "--compact" in argv else "full")
    tail = 20
    if "--tail" in argv:
        try:
            tail = int(argv[argv.index("--tail") + 1])
        except Exception:
            pass
    if not follow:
        print(render(mode, tail))
        return
    try:
        while True:
            sys.stdout.write("\033[2J\033[H")
            sys.stdout.write(render(mode, tail) + "\n")
            sys.stdout.flush()
            time.sleep(1)
    except KeyboardInterrupt:
        sys.stdout.write(RST + "\n")


if __name__ == "__main__":
    main()
