class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, *a):
        pass  # quiet

    def _send(self, code, body, ctype):
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body if isinstance(body, bytes) else body.encode())

    def do_GET(self):
        if self.path.rstrip("/") in ("", "/index.html") or self.path == "/":
            self._send(200, PAGE, "text/html; charset=utf-8")
        elif self.path.rstrip("/").endswith("data"):
            try:
                self._send(200, json.dumps(snapshot()), "application/json")
            except Exception:
                self._send(200, json.dumps({"error": "snapshot failed", "run": {}, "tasks": [],
                                            "agents": {}, "activity": []}), "application/json")
        else:
            self._send(404, "not found", "text/plain")

    def do_POST(self):          # read-only: no mutating endpoint exists
        self._send(405, "read-only dashboard", "text/plain")


def main():
    ap = argparse.ArgumentParser(description="Read-only Orbit web board over .orbit/")
    ap.add_argument("--port", type=int, default=0, help="port (0 = auto-pick)")
    ap.add_argument("--once", action="store_true", help="print the JSON snapshot and exit (no server)")
    args = ap.parse_args()
    if not ORBIT.is_dir():
        print(f"orbit-dashboard: no {ORBIT}/ here — run /orbit first, or set ORBIT_DIR.", file=sys.stderr)
        sys.exit(1)
    if args.once:
        print(json.dumps(snapshot(), indent=2))
        return
    with socketserver.TCPServer(("127.0.0.1", args.port), Handler) as httpd:
        port = httpd.server_address[1]
        print(f"🛰  Orbit board → http://127.0.0.1:{port}   (Ctrl-C to stop; read-only)", flush=True)
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            print("\nstopped.")


if __name__ == "__main__":
    main()
