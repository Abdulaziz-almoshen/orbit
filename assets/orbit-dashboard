 const human=agents.human||{},question=clean(run.blocked_question),project=s.project||{},attention=s.attention||{},session=s.session||{};
 const projectName=clean(project.name||project.product||'this project'),sid=clean(session.session_id||attention.session_id).slice(0,8);
 const owner=clean(session.model||session.agent||attention.source||'Claude Code');
 const reporter=agents.reporter||{};
 const activeTask=tasks.find(t=>['active','in_progress','doing'].includes(String(t.status||'').toLowerCase()));
 const activeAgent=Object.values(agents).find(a=>a&&a.status==='active'&&a.display&&!['You','Orchestrator'].includes(a.display));
 const recentDone=[...activity].reverse().find(e=>e&&e.status==='done'&&e.role!=='orchestrator'&&e.role!=='subagent');
 if(question&&(human.status==='blocked'||/question|permission|input|choose|approve/i.test(question))){
   const exact=attention.question_available&&clean(attention.message),where='Answer in '+clean(attention.answer_in||'the originating Claude Code terminal')+'.';
   return {mood:'question',eye:projectName+' · your answer is needed',
     say:exact?'Question: '+short(attention.message,105):owner+' needs your answer, but its notification did not include the question. Open the originating session to see it.',
     meta:owner+(sid?' · session '+sid:'')+' · '+where};}
 if(reviewing){const who=reviewing[0]==='codex'?'Codex':'Claude';return {mood:'qa',eye:who+' QA is working',say:who+' is reviewing the exact commit now.',meta:(head?'commit '+head+' · ':'')+'independent QA in progress'};}
 if(qa.status==='changes_required')return {mood:'blocked',eye:'QA returned findings',say:'QA sent the commit back. The builder needs to repair it before we can continue.',meta:(head?'commit '+head+' · ':'')+(qa.score!=null?qa.score+'/10':'changes required')};
 if(qa.status==='blocked'||qa.status==='error')return {mood:'blocked',eye:'QA needs attention',say:'The QA stage is blocked. Open the board to see the reason and next action.',meta:short(qa.reason||'QA runner blocked',90)};
 if(qa.status==='awaiting_deploy_approval')return {mood:'question',eye:'Deployment decision',say:'QA passed. The release is waiting for your deployment approval.',meta:(head?'commit '+head+' · ':'')+(qa.score!=null?qa.score+'/10 · ':'')+'human gate'};
 if(qa.verdict==='PASS')return {mood:'done',eye:'Independent QA passed',say:'Independent QA approved this exact commit. The reporter is preparing the handoff.',meta:(head?'commit '+head+' · ':'')+(qa.score!=null?qa.score+'/10':'passed')};
 if(reporter.status==='active')return {mood:'thinking',eye:'Reporter is closing out',say:'The build and checks are complete. I am preparing the result, proof, and remaining risks.',meta:head?'commit '+head:'final report'};
 if(activeTask||activeAgent)return {mood:'thinking',eye:'Code is building',say:(activeAgent?.display||'Claude')+' is working on '+taskName(activeTask)+'.',meta:'I will tell you when this task finishes.'};
 if(recentDone)return {mood:'done',eye:'Task finished',say:(recentDone.role||'The team')+' finished: '+short(recentDone.msg||recentDone.phase||'task complete',92),meta:head?'latest commit '+head:'checking the next task'};
 if(qa.status==='awaiting_review')return {mood:'thinking',eye:'Commit ready for QA',say:'The build is committed. Independent QA has not started yet.',meta:head?'commit '+head:'waiting for a commit'};
 return {mood:'thinking',eye:'Watching the board',say:'I am tracking the task board, QA, commits, questions, and deployment.',meta:head?'HEAD '+head:'waiting for activity'};}
function speak(text){if(!voiceOn||!('speechSynthesis'in window))return;speechSynthesis.cancel();const u=new SpeechSynthesisUtterance(text);u.rate=1.02;u.volume=.7;speechSynthesis.speak(u)}
async function tick(){try{const r=await fetch('/data',{cache:'no-store'}),s=await r.json(),x=report(s),key=[x.mood,x.eye,x.say,x.meta].join('|');if(key!==lastKey){lastKey=key;pet.dataset.mood=x.mood;eyebrow.textContent=x.eye;say.textContent=x.say;meta.textContent=x.meta;speak(x.say)}}catch(e){pet.dataset.mood='blocked';eyebrow.textContent='Board connection lost';say.textContent='I cannot reach Orbit right now.';meta.textContent='Restart scripts/orbit-dashboard'}}
voice.onclick=()=>{voiceOn=!voiceOn;voice.textContent=voiceOn?'🔊':'🔇';voice.classList.toggle('on',voiceOn);if(voiceOn)speak(say.textContent)};
tick();setInterval(tick,2000);
