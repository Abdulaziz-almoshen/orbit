#!/usr/bin/env python3
"""
orbit-dashboard — a READ-ONLY local web board over a repo's .orbit/ state. The premium view of the same
event stream orbit-status renders in the terminal: plan/checklist, active agents + current owner, gates,
budget (cost/time/tokens), confidence, the writer lock, decisions, and scaffold freshness.

  scripts/orbit-dashboard              # serve on an auto-picked port, print the URL
  scripts/orbit-dashboard --port 8765  # a fixed port
  scripts/orbit-dashboard --once       # print the JSON snapshot and exit (no server; for scripts/tests)

Read-only by construction — it never writes .orbit/ and exposes no mutating endpoint. Secrets are
redacted; empty/missing/malformed files degrade to empty sections and never crash the page.
"""
from __future__ import annotations

import argparse
import http.server
import json
import os
import re
import socketserver
import subprocess
import sys
import time
from pathlib import Path

ORBIT = Path(os.environ.get("ORBIT_DIR", ".orbit"))

# Redact anything that looks like a credential before it reaches the page.
_SECRET = re.compile(
    r'(?i)\b(api[_-]?key|secret|token|password|passwd|bearer|authorization|client[_-]?secret)\b'
    r'\s*[:=]\s*["\']?[^\s"\',}]{6,}')
_SECRET2 = re.compile(r'\b(sk-[A-Za-z0-9]{12,}|ghp_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,})')


def _redact(obj):
    """Recursively redact secret-looking strings anywhere in the snapshot."""
    if isinstance(obj, str):
        s = _SECRET.sub(lambda m: m.group(1) + "=[redacted]", obj)
        return _SECRET2.sub("[redacted]", s)
    if isinstance(obj, list):
        return [_redact(x) for x in obj]
    if isinstance(obj, dict):
        return {k: _redact(v) for k, v in obj.items()}
    return obj


def _json(name, default):
    try:
        v = json.loads((ORBIT / name).read_text())
        return v
    except Exception:
        return default


def _jsonl(name, tail=200):
    out = []
    try:
        for ln in (ORBIT / name).read_text().splitlines()[-tail:]:
            try:
                out.append(json.loads(ln))
            except Exception:
                continue                       # a truncated/garbage line never breaks the feed
    except Exception:
        pass
    return out


def _age(ts_iso):
    try:
        t = time.strptime(str(ts_iso), "%Y-%m-%dT%H:%M:%SZ")
        return max(0, int(time.time() - time.mktime(t) + time.timezone))
    except Exception:
        return None


def _git(*args):
    try:
        p = subprocess.run(["git", "-C", str(ORBIT.parent), *args], text=True, capture_output=True,
                           timeout=3)
        return p.stdout.strip() if p.returncode == 0 else ""
    except Exception:
        return ""


def _meaningful_worktree_dirty() -> bool:
    ignored = (".orbit/activity.jsonl", ".orbit/agents.json", ".orbit/run.json",
               ".orbit/tasks.json", ".orbit/locks/", ".orbit/archive/", ".orbit/.last-task-route")
    for line in _git("status", "--porcelain").splitlines():
        path = line[3:].split(" -> ")[-1] if len(line) > 3 else ""
        if path and not any(path == x or path.startswith(x) for x in ignored):
            return True
    return False


def _qa_state():
    """Exact-HEAD independent-QA pipeline state from Git's out-of-worktree control plane."""
    cfg = _json("loop.config.json", {}) or {}
    iq = (cfg.get("independent_qa") or {}) if isinstance(cfg, dict) else {}
    enabled = bool(iq.get("enabled"))
    export = iq.get("external_export") if isinstance(iq.get("external_export"), dict) else {}
    approved = export.get("approved") is True
    provider_cfg = iq.get("provider") if isinstance(iq.get("provider"), dict) else {}
    provider = provider_cfg.get("mode") or provider_cfg.get("name") or "claude"
    head = _git("rev-parse", "HEAD")
    common = _git("rev-parse", "--git-common-dir")
    control = {}
    try:
        cp = Path(common)
        if common and not cp.is_absolute():
            cp = (ORBIT.parent / cp).resolve()
        candidate = cp / "orbit-independent-qa" / "current.json"
        if common and candidate.is_file():
            value = json.loads(candidate.read_text())
            if isinstance(value, dict) and value.get("schema_version") == 1:
                control = value
    except Exception:
        pass
    status = "off" if not enabled else ("awaiting_project_approval" if not approved else "awaiting_review")
    exact = bool(head and control.get("target_commit") == head)
    if enabled and approved and exact:
        status = control.get("status") or "awaiting_review"
    verdict = control.get("verdict") if exact else None
    score = control.get("score") if exact else None
    deploy = ((cfg.get("approval_checkpoints") or {}).get("deploy")
              if isinstance(cfg, dict) else None)
    if status == "pass":
        status = "awaiting_deploy_approval" if deploy == "human" else (
            "deploy_forbidden" if deploy == "FORBIDDEN" else "ready_to_deploy")
    dirty = _meaningful_worktree_dirty()
    provider_states = control.get("providers") if exact and isinstance(control.get("providers"), dict) else {}
    return {"enabled": enabled, "export_approved": approved, "provider": provider,
            "status": status, "verdict": verdict, "score": score, "head": head,
            "target_commit": control.get("target_commit"), "request_id": control.get("request_id"),
            "round": control.get("round"), "reason": control.get("reason", ""),
            "updated_at": control.get("updated_at"), "exact_commit": exact, "dirty": dirty,
            "deployment_gate": deploy, "providers": provider_states}


def snapshot() -> dict:
    """The whole board as one redacted, JSON-safe object. Every field degrades to empty, never raises."""
    run = _json("run.json", {}) or {}
    tasks = _json("tasks.json", []) or []
    agents = _json("agents.json", {}) or {}
    agents = agents if isinstance(agents, dict) else {}
    lock = _json("locks/active-writer.json", None)
    setup = _json("setup.json", {}) or {}
    attention = _json("attention.json", None)
    sessions = _json("sessions.json", {}) or {}
    wanted_session = ((attention or {}).get("session_id") if isinstance(attention, dict) else None) or (
        lock.get("session_id") if isinstance(lock, dict) else None)
    session = sessions.get(wanted_session) if wanted_session and isinstance(sessions, dict) else None
    decisions = []
    dfile = ORBIT / "decisions"
    if dfile.is_dir():
        for p in sorted(dfile.glob("*.json"))[-20:]:
            d = _json(f"decisions/{p.name}", None)
            if isinstance(d, dict):
                decisions.append(d)
    snap = {
        "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "project": {"name": ORBIT.parent.name,
                    "product": setup.get("product") if isinstance(setup, dict) else ""},
        "run": run,
        "tasks": tasks if isinstance(tasks, list) else [],
        "agents": agents,
        "active_actors": [v.get("display") or k for k, v in agents.items()
                          if isinstance(v, dict) and v.get("status") == "active"],
        "activity": _jsonl("activity.jsonl", 120),
        "writer_lock": lock if isinstance(lock, dict) else None,
        "attention": attention if isinstance(attention, dict) else None,
        "session": session if isinstance(session, dict) else ({"session_id": wanted_session,
                    "agent": "Claude Code", "model": "model not reported"} if wanted_session else None),
        "lock_stale": bool(lock and isinstance(lock, dict)
                           and (_age(lock.get("heartbeat_at")) or 0) > int(lock.get("ttl_seconds") or 1800)),
        "decisions": decisions,
        "confidence": run.get("confidence") if isinstance(run, dict) else None,
        "qa": _qa_state(),
    }
    return _redact(snap)


