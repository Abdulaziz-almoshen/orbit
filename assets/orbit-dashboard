.pet{height:116px;position:relative;filter:drop-shadow(0 10px 16px rgba(0,0,0,.45));animation:float 3s ease-in-out infinite}
.body{position:absolute;left:15px;bottom:5px;width:78px;height:88px;border-radius:44% 44% 40% 40%/48% 48% 38% 38%;background:linear-gradient(145deg,#d97757,#a84f39);border:2px solid rgba(255,255,255,.12)}
.ear{position:absolute;top:-8px;width:25px;height:28px;background:#b95d43;border-radius:7px 19px 5px 18px}.ear.l{left:4px;transform:rotate(-18deg)}.ear.r{right:4px;transform:scaleX(-1) rotate(-18deg)}
.eye{position:absolute;top:31px;width:8px;height:9px;border-radius:50%;background:#111}.eye.l{left:21px}.eye.r{right:21px}.mouth{position:absolute;left:31px;top:53px;width:16px;height:8px;border-bottom:3px solid #20100c;border-radius:0 0 12px 12px}
.badge{position:absolute;right:-5px;top:4px;width:18px;height:18px;border-radius:50%;background:var(--blue);border:3px solid var(--bg)}
.pet[data-mood=question] .badge{background:var(--amber);animation:ping 1.1s infinite}.pet[data-mood=qa] .badge{background:#10a37f;animation:ping 1.1s infinite}.pet[data-mood=done] .badge{background:var(--green)}.pet[data-mood=blocked] .badge{background:var(--red)}
.pet[data-mood=thinking] .eye{animation:blink 2.4s infinite}.pet[data-mood=qa] .body{animation:scan 1.4s ease-in-out infinite}
.label{text-align:center;position:absolute;bottom:-8px;width:100%;font-size:10px;color:var(--dim);letter-spacing:.04em;text-transform:uppercase}
.bubble{align-self:start;margin-top:8px;background:rgba(22,27,34,.96);border:1px solid var(--line);border-radius:15px 15px 15px 5px;min-height:126px;padding:14px 15px;box-shadow:0 14px 32px rgba(0,0,0,.38);position:relative}
.eyebrow{font-size:10px;color:var(--blue);font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:7px}.say{font-size:14px;font-weight:650;line-height:1.45;max-height:66px;overflow:hidden}.meta{font:10px/1.3 ui-monospace,SFMono-Regular,Menlo,monospace;color:var(--dim);margin-top:9px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.voice{position:absolute;right:8px;top:7px;border:0;background:transparent;color:var(--dim);font-size:14px;cursor:pointer}.voice.on{color:var(--green)}
@keyframes float{50%{transform:translateY(-5px)}}@keyframes ping{50%{transform:scale(.72);opacity:.55}}@keyframes blink{48%,52%{height:2px;top:35px}}@keyframes scan{50%{filter:drop-shadow(0 0 8px #10a37f)}}
</style></head><body><main class=shell>
