#!/usr/bin/env python3
"""
orbit-dashboard — a READ-ONLY local web board over a repo's .orbit/ state. The premium view of the same
event stream orbit-status renders in the terminal: plan/checklist, active agents + current owner, gates,
budget (cost/time/tokens), confidence, the writer lock, decisions, and scaffold freshness.

  scripts/orbit-dashboard              # serve on an auto-picked port, print the URL
  scripts/orbit-dashboard --port 8765  # a fixed port
  scripts/orbit-dashboard --once       # print the JSON snapshot and exit (no server; for scripts/tests)

Read-only by construction — it never writes .orbit/ and exposes no mutating endpoint. Secrets are
redacted; empty/missing/malformed files degrade to empty sections and never crash the page.
"""
from __future__ import annotations

import argparse
import http.server
import json
import os
import re
import socketserver
import subprocess
import sys
import time
from pathlib import Path
from urllib.parse import urlencode

ORBIT = Path(os.environ.get("ORBIT_DIR", ".orbit"))

# Redact anything that looks like a credential before it reaches the page.
_SECRET = re.compile(
    r'(?i)\b(api[_-]?key|secret|token|password|passwd|bearer|authorization|client[_-]?secret)\b'
    r'\s*[:=]\s*["\']?[^\s"\',}]{6,}')
_SECRET2 = re.compile(r'\b(sk-[A-Za-z0-9]{12,}|ghp_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,})')


def _redact(obj):
    """Recursively redact secret-looking strings anywhere in the snapshot."""
    if isinstance(obj, str):
        s = _SECRET.sub(lambda m: m.group(1) + "=[redacted]", obj)
        return _SECRET2.sub("[redacted]", s)
    if isinstance(obj, list):
        return [_redact(x) for x in obj]
    if isinstance(obj, dict):
        return {k: _redact(v) for k, v in obj.items()}
    return obj


def _json(name, default):
    try:
        v = json.loads((ORBIT / name).read_text())
        return v
    except Exception:
        return default


def _jsonl(name, tail=200):
    out = []
    try:
        for ln in (ORBIT / name).read_text().splitlines()[-tail:]:
            try:
                out.append(json.loads(ln))
            except Exception:
                continue                       # a truncated/garbage line never breaks the feed
    except Exception:
        pass
    return out


def _age(ts_iso):
    try:
        t = time.strptime(str(ts_iso), "%Y-%m-%dT%H:%M:%SZ")
        return max(0, int(time.time() - time.mktime(t) + time.timezone))
    except Exception:
        return None


def _git(*args):
    try:
        p = subprocess.run(["git", "-C", str(ORBIT.parent), *args], text=True, capture_output=True,
                           timeout=3)
        return p.stdout.strip() if p.returncode == 0 else ""
    except Exception:
        return ""


def _meaningful_worktree_dirty() -> bool:
    ignored = (".orbit/activity.jsonl", ".orbit/agents.json", ".orbit/run.json",
               ".orbit/tasks.json", ".orbit/locks/", ".orbit/archive/", ".orbit/.last-task-route")
    for line in _git("status", "--porcelain").splitlines():
        path = line[3:].split(" -> ")[-1] if len(line) > 3 else ""
        if path and not any(path == x or path.startswith(x) for x in ignored):
            return True
    return False


def _qa_state():
    """Exact-HEAD independent-QA pipeline state from Git's out-of-worktree control plane."""
    cfg = _json("loop.config.json", {}) or {}
    iq = (cfg.get("independent_qa") or {}) if isinstance(cfg, dict) else {}
    enabled = bool(iq.get("enabled"))
    export = iq.get("external_export") if isinstance(iq.get("external_export"), dict) else {}
    approved = export.get("approved") is True
    provider_cfg = iq.get("provider") if isinstance(iq.get("provider"), dict) else {}
    provider = provider_cfg.get("mode") or provider_cfg.get("name") or "claude"
    head = _git("rev-parse", "HEAD")
    common = _git("rev-parse", "--git-common-dir")
    control = {}
    try:
        cp = Path(common)
        if common and not cp.is_absolute():
            cp = (ORBIT.parent / cp).resolve()
        candidate = cp / "orbit-independent-qa" / "current.json"
        if common and candidate.is_file():
            value = json.loads(candidate.read_text())
            if isinstance(value, dict) and value.get("schema_version") == 1:
                control = value
    except Exception:
        pass
    status = "off" if not enabled else ("awaiting_project_approval" if not approved else "awaiting_review")
    exact = bool(head and control.get("target_commit") == head)
    if enabled and approved and exact:
        status = control.get("status") or "awaiting_review"
    verdict = control.get("verdict") if exact else None
    score = control.get("score") if exact else None
    deploy = ((cfg.get("approval_checkpoints") or {}).get("deploy")
              if isinstance(cfg, dict) else None)
    if status == "pass":
        status = "awaiting_deploy_approval" if deploy == "human" else (
            "deploy_forbidden" if deploy == "FORBIDDEN" else "ready_to_deploy")
    dirty = _meaningful_worktree_dirty()
    provider_states = control.get("providers") if exact and isinstance(control.get("providers"), dict) else {}
    return {"enabled": enabled, "export_approved": approved, "provider": provider,
            "status": status, "verdict": verdict, "score": score, "head": head,
            "target_commit": control.get("target_commit"), "request_id": control.get("request_id"),
            "round": control.get("round"), "reason": control.get("reason", ""),
            "updated_at": control.get("updated_at"), "exact_commit": exact, "dirty": dirty,
            "deployment_gate": deploy, "providers": provider_states}


def _duration(seconds):
    if seconds is None:
        return ""
    if seconds < 60:
        return f"{seconds}s"
    if seconds < 3600:
        return f"{seconds // 60}m"
    return f"{seconds // 3600}h {seconds % 3600 // 60}m"


def _task_title(task, fallback="the current task"):
    if not isinstance(task, dict):
        return fallback
    return str(task.get("subject") or task.get("title") or task.get("text") or
               task.get("name") or task.get("id") or fallback).strip()


def _reporter_state(snap):
    """Turn raw Orbit telemetry into one prioritized, actionable situation.

    The pet and any future reporter surfaces consume this same model, so urgency, progress, and the
    promised action cannot drift between clients. Actions are local custom URLs handled by the native
    shell; the dashboard remains read-only.
    """
    run = snap.get("run") if isinstance(snap.get("run"), dict) else {}
    qa = snap.get("qa") if isinstance(snap.get("qa"), dict) else {}
    tasks = snap.get("tasks") if isinstance(snap.get("tasks"), list) else []
    agents = snap.get("agents") if isinstance(snap.get("agents"), dict) else {}
    attention = snap.get("attention") if isinstance(snap.get("attention"), dict) else {}
    session = snap.get("session") if isinstance(snap.get("session"), dict) else {}
    project = snap.get("project") if isinstance(snap.get("project"), dict) else {}
    project_name = str(project.get("name") or project.get("product") or "Project")
    sid = str(session.get("session_id") or attention.get("session_id") or "")
    model = str(session.get("model") or session.get("agent") or attention.get("source") or "Claude Code")
    active_states = {"active", "in_progress", "in-progress", "doing", "working"}
    done_states = {"done", "completed", "complete", "passed"}
    active_task = next((t for t in tasks if isinstance(t, dict) and
                        str(t.get("status", "")).lower() in active_states), None)
    pending = [t for t in tasks if isinstance(t, dict) and
               str(t.get("status", "")).lower() not in active_states | done_states]
    completed = sum(1 for t in tasks if isinstance(t, dict) and
                    str(t.get("status", "")).lower() in done_states)
    total = len(tasks) or int(run.get("tasks_total") or 0)
    done = completed if tasks else int(run.get("tasks_done") or 0)
    current = str(run.get("active_task") or _task_title(active_task, ""))
    next_task = _task_title(pending[0], "") if pending else ""
    active_agent = next((a for a in agents.values() if isinstance(a, dict) and
                         a.get("status") == "active" and
                         (a.get("display") or "") not in ("You", "Orchestrator")), None)
    actor = str((active_agent or {}).get("display") or run.get("active_role") or model)
    started = (active_agent or {}).get("started_at") or run.get("started_at")
    elapsed = _age(started)
    quiet = _age(run.get("last_ts"))
    head = str(qa.get("head") or "")
    providers = qa.get("providers") if isinstance(qa.get("providers"), dict) else {}
    reviewing = next((name for name, state in providers.items()
                      if isinstance(state, dict) and state.get("status") == "reviewing"), "")

    query = urlencode({"session": sid, "project": str(ORBIT.parent.resolve()),
                       "terminal_program": session.get("terminal_program") or "",
                       "terminal_session": session.get("terminal_session") or "",
                       "terminal_bundle": session.get("terminal_bundle") or ""})
    focus = {"kind": "focus_session", "label": "Focus session",
             "url": "orbit-action://focus-session?" + query}
    board = {"kind": "open_board", "label": "Open board", "url": "orbit-action://open-board"}
    state, urgency = "idle", "normal"
    title, summary, next_action = "Watching Orbit", "No active work is reported yet.", "Waiting for activity."

    question = str(run.get("blocked_question") or attention.get("message") or "").strip()
    needs_input = bool(question and (run.get("blocked_question") or attention.get("question_available") or
                                     re.search(r"question|permission|input|choose|approve", question, re.I)))
    if needs_input:
        state, urgency = "needs_action", "critical"
        title = "Your answer is needed"
        summary = ("Question: " + question) if attention.get("question_available") else (
            f"{model} paused and needs your input. Open the session to see the prompt and answer.")
        where = str(attention.get("answer_in") or "").strip()
        next_action = (where if re.match(r"^(answer|open|choose|approve|review)\b", where, re.I)
                       else f"Answer in {where}." if where
                       else "Open the originating session and answer there.")
    elif qa.get("status") == "changes_required":
        state, urgency, title = "blocked", "high", "QA returned findings"
        summary = "The exact commit was rejected and must be repaired before the pipeline continues."
        next_action = str(qa.get("reason") or "Open the board for the findings and repair status.")
    elif qa.get("status") in ("blocked", "error"):
        state, urgency, title = "blocked", "high", "QA is blocked"
        summary = str(qa.get("reason") or "The independent reviewer cannot continue.")
        next_action = "Open the board to inspect the gate and owner."
    elif reviewing:
        who = "Codex" if reviewing == "codex" else "Claude QA" if reviewing == "claude" else reviewing.title()
        state, title = "qa", f"{who} is reviewing"
        summary = f"Independent QA is checking exact commit {head[:8] or 'pending'}."
        next_action = "The builder waits for PASS or repair findings."
    elif qa.get("status") == "awaiting_deploy_approval":
        state, urgency, title = "needs_action", "critical", "Deployment needs approval"
        summary = f"Independent QA passed commit {head[:8] or 'the current commit'}."
        next_action = "Open the board and make the deployment decision."
    elif current or active_task or active_agent:
        state, title = "working", f"{actor} is working"
        summary = current or _task_title(active_task)
        next_action = (f"Next: {next_task}" if next_task else "I will report the next state change.")
        if quiet is not None and quiet >= 180:
            state, urgency, title = "stalled", "high", "Work may need attention"
            next_action = f"No new Orbit signal for {_duration(quiet)}. Focus the session to inspect it."
        elif elapsed is not None and elapsed >= 600:
            state, urgency, title = "slow", "medium", "This task is taking time"
            next_action = f"Running for {_duration(elapsed)}; last signal {_duration(quiet) or 'just now'} ago."
    elif qa.get("status") == "awaiting_review":
        state, title = "qa_ready", "Commit is ready for QA"
        summary = f"Commit {head[:8] or 'HEAD'} is queued for independent review."
        next_action = "Waiting for the configured QA provider to start."
    elif total and done >= total:
        state, title = "done", "All reported tasks are complete"
        summary = f"{done} of {total} tasks finished."
        next_action = "Open the board for QA, commit, and deployment status."

    return {"schema_version": 1, "state": state, "urgency": urgency, "title": title,
            "summary": summary, "next_action": next_action, "project": project_name,
            "actor": actor, "model": model, "session_id": sid, "current_task": current,
            "next_task": next_task, "tasks_done": done, "tasks_total": total,
            "progress_percent": round(100 * done / total) if total else 0,
            "elapsed_seconds": elapsed, "elapsed": _duration(elapsed),
            "quiet_seconds": quiet, "quiet": _duration(quiet), "qa_status": qa.get("status"),
            "commit": head[:8], "primary_action": focus if sid else board,
            "secondary_action": board if sid else None,
            "event_key": "|".join(str(x) for x in (state, question, current, qa.get("status"), head, done, total))}


def snapshot() -> dict:
    """The whole board as one redacted, JSON-safe object. Every field degrades to empty, never raises."""
    run = _json("run.json", {}) or {}
    tasks = _json("tasks.json", []) or []
    agents = _json("agents.json", {}) or {}
    agents = agents if isinstance(agents, dict) else {}
    lock = _json("locks/active-writer.json", None)
    setup = _json("setup.json", {}) or {}
    attention = _json("attention.json", None)
    sessions = _json("sessions.json", {}) or {}
    wanted_session = ((attention or {}).get("session_id") if isinstance(attention, dict) else None) or (
        lock.get("session_id") if isinstance(lock, dict) else None)
    session = sessions.get(wanted_session) if wanted_session and isinstance(sessions, dict) else None
    decisions = []
    dfile = ORBIT / "decisions"
    if dfile.is_dir():
        for p in sorted(dfile.glob("*.json"))[-20:]:
            d = _json(f"decisions/{p.name}", None)
            if isinstance(d, dict):
                decisions.append(d)
    snap = {
        "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "project": {"name": ORBIT.parent.resolve().name,
                    "product": setup.get("product") if isinstance(setup, dict) else ""},
        "run": run,
        "tasks": tasks if isinstance(tasks, list) else [],
        "agents": agents,
        "active_actors": [v.get("display") or k for k, v in agents.items()
                          if isinstance(v, dict) and v.get("status") == "active"],
        "activity": _jsonl("activity.jsonl", 120),
        "writer_lock": lock if isinstance(lock, dict) else None,
        "attention": attention if isinstance(attention, dict) else None,
        "session": session if isinstance(session, dict) else ({"session_id": wanted_session,
                    "agent": "Claude Code", "model": "model not reported"} if wanted_session else None),
        "lock_stale": bool(lock and isinstance(lock, dict)
                           and (_age(lock.get("heartbeat_at")) or 0) > int(lock.get("ttl_seconds") or 1800)),
        "decisions": decisions,
        "confidence": run.get("confidence") if isinstance(run, dict) else None,
        "qa": _qa_state(),
    }
    snap["reporter"] = _reporter_state(snap)
    return _redact(snap)


