#!/usr/bin/env python3
"""Build and control Orbit's macOS always-on-top reporter pet."""
from __future__ import annotations
import argparse, hashlib, json, os, signal, subprocess, sys, time, urllib.request
from pathlib import Path
from urllib.parse import urlparse

ROOT = Path(__file__).resolve().parent.parent
SOURCE = ROOT / "assets" / "orbit-pet.swift"
HOME = Path(os.environ.get("ORBIT_HOME", str(Path.home() / ".orbit")))
PID = HOME / "pet.pid"
STATE = HOME / "pet.json"
DASH_PID = HOME / "dashboard.pid"


def live_pid(path=PID):
    try:
        pid = int(path.read_text().strip())
        os.kill(pid, 0)
        return pid
    except Exception:
        return None


def ensure_dashboard(url: str, project: Path, follow_root: Path = None):
    """Start the read-only board when the reporter URL is not already available."""
    try:
        urllib.request.urlopen(url, timeout=1).read(256)
        return live_pid(DASH_PID)
    except Exception:
        pass
    # Always run the latest board shipped alongside this orbit-pet, so every project — however long ago
    # it was scaffolded — gets the current reporter. Fall back to the project's own wrapper if missing.
    dashboard = ROOT / "assets" / "orbit-dashboard"
    if not dashboard.is_file():
        dashboard = project / "scripts" / "orbit-dashboard"
    parsed = urlparse(url)
    if parsed.hostname not in ("127.0.0.1", "localhost") or not parsed.port or not dashboard.is_file():
        raise SystemExit(f"Orbit dashboard pet view is unavailable at {url}; run scripts/orbit-dashboard first")
    env = {**os.environ}
    if follow_root:
        env["ORBIT_FOLLOW"] = str(follow_root)     # board tracks the most-active project under this root
    log = (HOME / "dashboard.log").open("ab", buffering=0)
    # The scaffolded wrapper is +x; the raw repo source is not, so run it under the interpreter then.
    cmd = [str(dashboard), "--port", str(parsed.port)]
    if not os.access(dashboard, os.X_OK):
        cmd = [sys.executable, *cmd]
    proc = subprocess.Popen(cmd, cwd=project, env=env,
                            stdin=subprocess.DEVNULL, stdout=log, stderr=subprocess.STDOUT,
                            start_new_session=True)
    DASH_PID.write_text(str(proc.pid) + "\n")
    for _ in range(30):
        try:
            urllib.request.urlopen(url, timeout=.3).read(256)
            return proc.pid
        except Exception:
            time.sleep(.1)
    raise SystemExit(f"Orbit dashboard did not become ready at {url}; see {HOME / 'dashboard.log'}")


def binary():
    digest = hashlib.sha256(SOURCE.read_bytes()).hexdigest()[:12]
    cache = HOME / "cache"; cache.mkdir(parents=True, exist_ok=True)
    out = cache / f"orbit-pet-{digest}"
    if not out.exists():
        subprocess.run(["swiftc", str(SOURCE), "-o", str(out), "-framework", "Cocoa",
                        "-framework", "WebKit"], check=True)
    return out


def main():
    ap = argparse.ArgumentParser(description="Orbit floating reporter pet (macOS)")
    ap.add_argument("command", choices=("start", "stop", "status"), nargs="?", default="start")
    ap.add_argument("--url", default="http://127.0.0.1:8765/pet")
    ap.add_argument("--project", type=Path, default=Path.cwd())
    ap.add_argument("--follow", metavar="ROOT", default=None,
                    help="track the most-active project under ROOT (default: the project's parent dir)")
    ap.add_argument("--no-follow", action="store_true",
                    help="watch only --project, do not follow other repos")
    args = ap.parse_args(); HOME.mkdir(parents=True, exist_ok=True)
    pid = live_pid()
    if args.command == "status":
        state = {}
        try:
            state = json.loads(STATE.read_text())
        except Exception:
            pass
        print(json.dumps({"running": bool(pid), "pid": pid,
                          "url": state.get("url", args.url),
                          "project": state.get("project", str(args.project.resolve())),
                          "dashboard_running": bool(live_pid(DASH_PID)),
                          "dashboard_pid": live_pid(DASH_PID)}, indent=2)); return 0
    if args.command == "stop":
        if pid:
            os.kill(pid, signal.SIGTERM)
        dash_pid = live_pid(DASH_PID)
        if dash_pid:
            os.kill(dash_pid, signal.SIGTERM)
        PID.unlink(missing_ok=True)
        DASH_PID.unlink(missing_ok=True)
        STATE.unlink(missing_ok=True)
        print("Orbit reporter pet stopped." if pid else "Orbit reporter pet was not running."); return 0
    if sys.platform != "darwin":
        raise SystemExit("orbit-pet currently requires macOS")
    if pid:
        print(f"Orbit reporter pet already running (pid {pid})."); return 0
    project = args.project.resolve()
    # Follow by default: watch every repo under the project's parent, tracking whichever is active.
    follow_root = None if args.no_follow else (Path(args.follow).expanduser().resolve()
                                               if args.follow else project.parent)
    dashboard_pid = ensure_dashboard(args.url, project, follow_root)
    log = (HOME / "pet.log").open("ab", buffering=0)
    proc = subprocess.Popen([str(binary()), args.url], stdin=subprocess.DEVNULL,
                            stdout=log, stderr=subprocess.STDOUT, start_new_session=True)
    PID.write_text(str(proc.pid) + "\n")
    STATE.write_text(json.dumps({"pid": proc.pid, "url": args.url, "project": str(project),
                                 "follow_root": str(follow_root) if follow_root else None,
                                 "dashboard_pid": dashboard_pid}) + "\n")
    scope = f"following {follow_root}" if follow_root else project.name
    print(f"Orbit reporter pet started (pid {proc.pid}) · {scope} · {args.url}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
